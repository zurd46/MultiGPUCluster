  "query": "SELECT id, ts, actor, action, resource, ip, details\n             FROM audit_log\n            WHERE ($1::text IS NULL OR action   = $1)\n              AND ($2::text IS NULL OR actor    = $2)\n              AND ($3::text IS NULL OR resource = $3)\n            ORDER BY ts DESC\n            LIMIT $4",
