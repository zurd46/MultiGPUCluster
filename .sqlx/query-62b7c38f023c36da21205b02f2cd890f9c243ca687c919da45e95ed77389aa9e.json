  "query": "UPDATE api_keys SET\n              name       = COALESCE($2, name),\n              scope      = COALESCE($3, scope),\n              expires_at = CASE\n                              WHEN $4::bool THEN $5\n                              ELSE expires_at\n                           END\n           WHERE id = $1\n           RETURNING id, name, prefix, scope, created_at, last_used_at, expires_at, revoked_at",
