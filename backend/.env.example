# Copy to .env and fill in real values. Never commit .env.

BACKEND_DOMAIN=cluster.example.com

# Postgres
POSTGRES_PASSWORD=change-me-to-a-long-random-string

# JWT signing for the management backend
JWT_SECRET=change-me-to-a-256-bit-random-secret

# MinIO root credentials
MINIO_ROOT_USER=gpucluster
MINIO_ROOT_PASSWORD=change-me

# WireGuard hub (Headscale)
HEADSCALE_BASE_URL=https://cluster.example.com:443
